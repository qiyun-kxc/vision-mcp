# ======================================
# 小克的眼睛 — 敏感配置（API Keys）
# 复制为 secrets.env 后填入真实 key
# ⚠️ 不要提交到 Git！
# ======================================

# --- Google Gemini ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --- 阿里百炼 / DashScope ---
# 北京区（免费试用额度，也用于调用 Kimi K2.5）
DASHSCOPE_API_KEY_BEIJING=YOUR_DASHSCOPE_KEY_BEIJING
# 新加坡区（国际版）
DASHSCOPE_API_KEY_SINGAPORE=YOUR_DASHSCOPE_KEY_SINGAPORE

# --- 腾讯混元（图片理解）---
HUNYUAN_API_KEY=YOUR_HUNYUAN_API_KEY
