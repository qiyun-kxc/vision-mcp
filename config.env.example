# ======================================
# vision-mcp configuration
# ======================================

# --- Gemini ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --- Alibaba DashScope ---
# Beijing region (free trial quota, also used for Kimi K2.5)
DASHSCOPE_API_KEY_BEIJING=YOUR_DASHSCOPE_KEY_BEIJING
# Singapore region (optional)
DASHSCOPE_API_KEY_SINGAPORE=YOUR_DASHSCOPE_KEY_SINGAPORE

# --- Server ---
VISION_MCP_PORT=18092
VIDEO_TEMP_DIR=/tmp/vision-mcp-videos

# --- SSE path (external path visible to clients through Nginx) ---
# Eliminates the need for Nginx sub_filter rewriting.
# Set this to the full path clients will POST to, e.g. /vision/terminal/messages
SSE_MSG_PATH=/vision/terminal/messages
