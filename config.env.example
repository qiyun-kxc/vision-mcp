# ======================================
# Vision MCP — Configuration
# Copy this to config.env and fill in your API keys
# ======================================

# --- Gemini (primary for YouTube) ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- Alibaba DashScope (primary for Bilibili / Chinese content) ---
# Beijing region (free trial quota)
DASHSCOPE_API_KEY_BEIJING=YOUR_DASHSCOPE_BEIJING_KEY_HERE
# Singapore region (optional, lower latency from Asia-Pacific)
DASHSCOPE_API_KEY_SINGAPORE=YOUR_DASHSCOPE_SINGAPORE_KEY_HERE

# --- Bilibili cookie file path (optional, for B站 video download) ---
# Point this to a file containing a "Cookie: ..." line
# BILI_COOKIE_PATH=/path/to/bilibili-cookies.yml

# --- Public URL for serving temp video files to DashScope ---
# DashScope cannot accept large base64 payloads, so we serve files via nginx
# PUBLIC_URL_BASE=https://your-domain.com/tmp
# PUBLIC_DIR=/var/www/html/tmp

# --- Server port ---
VISION_MCP_PORT=18092

# --- Temp directory for downloaded videos ---
VIDEO_TEMP_DIR=/tmp/vision-mcp-videos
