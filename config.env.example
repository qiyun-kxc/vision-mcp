# ======================================
# 小克的眼睛 — 普通配置（非敏感）
# 复制为 config.env 后使用
# ======================================

# --- 服务端口 ---
VISION_MCP_PORT=18092

# --- 临时文件目录 ---
VIDEO_TEMP_DIR=/tmp/vision-mcp-videos

# --- SSE 路径（Nginx 外部可见路径）---
# 客户端通过 Nginx 访问的公开路径
# Node 内部监听 /messages，Nginx 将 /vision/messages 代理到 /messages
SSE_MSG_PATH=/vision/messages
